# Local development (SQLite)
DATABASE_URL=sqlite:///sizzzle.db
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me
EMAIL_VERIFICATION_REQUIRED=true
EMAIL_OTP_TTL_MINUTES=10
PASSWORD_RESET_OTP_TTL_MINUTES=10
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://sizzle.me,https://www.sizzle.me,https://sizzzle.me,https://www.sizzzle.me,https://api.sizzle.me,https://api.sizzzle.me
AUTO_INIT_DB=true
AUTO_SEED_DEMO_DATA=true
AUTO_RESET_SQLITE_ON_SCHEMA_MISMATCH=true
DEMO_OTP_FALLBACK=false
RESET_DB_ON_START=false
PUBLIC_API_BASE=https://api.sizzzle.me/api

# Optional Upstash Redis (OTP cache)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Alias supported by backend if you keep token under API_KEY name
UPSTASH_REDIS_API_KEY=

# Resend (email verification)
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=Sizzzle <noreply@sizzzle.me>
RESEND_FALLBACK_FROM_EMAIL=Sizzzle <onboarding@resend.dev>
RESEND_USER_AGENT=Sizzzle-Backend/1.0
EMAIL_BRAND_NAME=Sizzzle
APP_BASE_URL=https://sizzzle.me
APP_LOGO_URL=https://sizzzle.me/iconlogo.png

# Production (PostgreSQL on deployment)
# DATABASE_URL=postgresql://username:password@host:5432/dbname
# AUTO_SEED_DEMO_DATA=false
# AUTO_RESET_SQLITE_ON_SCHEMA_MISMATCH=false
